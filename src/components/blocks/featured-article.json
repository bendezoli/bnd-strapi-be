{
  "collectionName": "components_blocks_featured_articles",
  "info": {
    "displayName": "Featured Article"
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "text",
      "maxLength": 100
    },
    "link": {
      "type": "component",
      "component": "elements.link",
      "repeatable": false
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "reversed": {
      "type": "boolean",
      "default": false
    },
    "headingTag": {
      "type": "enumeration",
      "required": false,
      "default": "p",
      "enum": [
        "h2",
        "h3",
        "h4",
        "h5",
        "h6",
        "p"
      ]
    },
    "padding": {
      "type": "enumeration",
      "default": "none",
      "enum": [
        "none",
        "small",
        "medium",
        "large"
      ]
    },
    "backgroundColor": {
      "type": "enumeration",
      "default": "none",
      "enum": [
        "none",
        "blue",
        "oceanblue"
      ]
    }
  },
  "config": {}
}
